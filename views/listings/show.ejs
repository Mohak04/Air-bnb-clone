<% layout('/layouts/boilerplate') %>

  <body style="background-color: aliceblue;">
    <script>
      let mapToken = "<%=process.env.MAP_TOKEN%>"
      let coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
      // console.log(coordinates);
      let loc="<%=listing.location%>"
      console.log(loc);
    </script>
    <div class="row mt-3">
      <div class="col-8 offset-1">
        <h3>
          <%=listing.title%>
        </h3>
      </div>
      <div class="card show col-6  offset-1">
        <img src="<%=listing.image.url%>" class="card-img-top" alt="listing">
        <div class="card-body show-page">
          <p class="card-text">
            <i><b>Owned by @<%=listing.owner.username%></b></i>
            <br>
            <%=listing.description%><br>
              &#8377;<%=listing.price.toLocaleString("en-IN")%><br>
                <%=listing.location%><br>
                  <%=listing.country%><br>
          </p>
        </div>
        <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
          <div class="row mb-3 mt-3">
            <div class="show-edit col-1">
              <a class="btn btn-dark add-btn" href="/listings/edit/<%=listing.id%>">Edit</a>
            </div>
            <div class="show-dlt col-1">
              <form method="post" action="/listings/delete/<%=listing.id%>?_method=delete">
                <button class="btn btn-dark btn-dlt">Delete</button>
              </form>
            </div>
          </div>
          <% } %>

      </div>

      <div class="col-6 offset-1 mb-3 mt-3">

        <hr>
        <h4>Leave a Review</h4>
        <form method="Post" action="/listings/<%=listing.id%>/reviews" novalidate class="needs-validation">
          <div>
            <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div>
            <label for="comment" class="form-label">Comment</label>
            <textarea rows="5" cols="30" id="comment" name="review[comment]" class="form-control" required></textarea>
            <div class="invalid-feedback">Please submit comment</div>
            <!-- <div class="valid-feedback">Good</div> -->
          </div>
          <button class="btn btn-outline-dark mt-3">Submit</button>
        </form>

        <% if(listing.reviews.length){ %>
          <hr><br>
          <h3>All Reviews</h3>
          <br>
          <div class="row">
            <% for(review of listing.reviews) { %>
              <div class="card col-5 mb-3 ms-3 review-card">
                <div class="card-body">
                  <h5 class="card-title">@<%=review.author.username%>
                  </h5>
                  <p class="card-text starability-result" data-rating=<%=review.rating %>>
                  </p>
                  <p class="card-text">
                    <%= review.comment %>
                  </p>
                  <form class="mb-3" method="post"
                    action="/listings/<%=listing.id%>/reviews/<%=review.id%>?_method=delete">
                    <button class="btn btn-sm btn-dark">Delete</button>
                  </form>
                </div>
              </div>
              <% } %>
          </div>
          <% } %>
      </div>
      <div class="col-6 offset-1 mb-3 mt-3">
        <h3>Where you'll be</h3>
        <div id="map"></div>
      </div>
    </div>

    <script src="/js/map.js"></script>
  </body>